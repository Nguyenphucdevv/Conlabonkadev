<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản lý Thư Viện</title>
    <link rel="icon" type="image/jpeg" href="/images/thuvienavt.jpg" />
    <!-- Favicon - File JPG -->
    <!-- Đảm bảo file thuvienavt.jpg nằm trong thư mục public/images/ -->
    <link rel="icon" type="image/jpeg" href="/images/thuvienavt.jpg" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <link rel="stylesheet" href="/thuvien.css" />

    <!-- Script định nghĩa các hàm global TRƯỚC KHI body render -->
    <script>
      // ===== HÀM XỬ LÝ XÓA THƯ VIỆN - ĐỊNH NGHĨA SỚM =====
      window.handleDeleteLibraryClick = async function (id, name) {
        console.log("🗑️ ===== handleDeleteLibraryClick CALLED =====");
        console.log("🗑️ ID:", id);
        console.log("🗑️ Name:", name);

        if (!id) {
          alert("❌ Không tìm thấy ID thư viện");
          console.error("❌ ID is empty or undefined");
          return;
        }

        const libraryName = name || "thư viện này";
        console.log("🗑️ Library name:", libraryName);

        const confirmMessage = `Bạn có chắc chắn muốn xóa thư viện "${libraryName}"?\n\nLưu ý: Tất cả sách trong thư viện này cũng sẽ bị xóa khỏi danh sách.`;
        console.log("🗑️ Confirm message:", confirmMessage);

        const confirmed = confirm(confirmMessage);
        console.log("🗑️ User confirmed:", confirmed);

        if (confirmed) {
          try {
            console.log("🗑️ Đang gửi yêu cầu xóa thư viện ID:", id);
            const url = `/admin/thu_vien/delete/${id}`;
            console.log("🗑️ URL:", url);

            const response = await fetch(url, {
              method: "DELETE",
              headers: {
                "Content-Type": "application/json",
              },
            });

            console.log("📥 Response status:", response.status);
            console.log("📥 Response ok:", response.ok);

            let result;
            try {
              result = await response.json();
              console.log("📥 Response JSON:", result);
            } catch (jsonError) {
              const text = await response.text();
              console.error("❌ Không parse được JSON:", text);
              console.error("❌ JSON Error:", jsonError);
              throw new Error(`Server trả về lỗi: ${text}`);
            }

            if (response.ok && result.success) {
              alert("✅ " + (result.message || "Xóa thư viện thành công!"));
              console.log("✅ Xóa thành công, đang reload trang...");
              window.location.reload();
            } else {
              alert("❌ Lỗi: " + (result.error || "Không thể xóa thư viện"));
              console.error("❌ Lỗi xóa thư viện:", result);
            }
          } catch (error) {
            console.error("❌ Lỗi khi gửi yêu cầu xóa:", error);
            console.error("❌ Error stack:", error.stack);
            alert("❌ Lỗi kết nối: " + error.message);
          }
        } else {
          console.log("🗑️ User cancelled deletion");
        }
      };

      // Hàm xử lý xem sách
      window.handleViewBooksClick = async function (id, name) {
        console.log("📚 handleViewBooksClick - ID:", id, "Name:", name);

        const labelEl = document.getElementById("booksModalLabel");
        if (labelEl) {
          labelEl.textContent = "";
          const icon = document.createElement("i");
          icon.className = "bi bi-book me-2";
          labelEl.appendChild(icon);
          labelEl.appendChild(
            document.createTextNode("Quản lý sách - " + (name || ""))
          );
        }

        const booksModalEl = document.getElementById("booksModal");
        if (!booksModalEl) {
          console.error("❌ Không tìm thấy booksModal element");
          alert("❌ Không tìm thấy modal sách. Vui lòng tải lại trang.");
          return;
        }

        // Hiện loading ngay
        const contentEl = document.getElementById("booksContent");
        if (contentEl) {
          contentEl.innerHTML = `
            <div class="text-center py-4">
              <div class="spinner-border text-primary" role="status"></div>
              <p class="mt-3 text-muted">Đang tải sách thư viện...</p>
            </div>
          `;
        }

        const booksModal = new bootstrap.Modal(booksModalEl);
        booksModal.show();

        // Load dữ liệu ngay sau khi show
        try {
          await window.loadLibraryBooks(id);
        } catch (error) {
          console.error("❌ Lỗi khi load sách:", error);
          if (contentEl) {
            contentEl.innerHTML = `
              <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Lỗi:</strong> ${error.message}
              </div>
            `;
          }
        }
      };

      // Hàm load sách thư viện - Gọi API backend và render bảng sách trong modal
      window.loadLibraryBooks = async function (libraryId) {
        console.log("📚 loadLibraryBooks - libraryId:", libraryId);
        const content = document.getElementById("booksContent");
        if (!content) return;

        try {
          const response = await fetch("/admin/thu_vien/books/" + libraryId);
          const data = await response.json();

          if (!response.ok || !data.success) {
            throw new Error(data.error || "Lỗi khi tải dữ liệu sách");
          }

          const books = data.books || [];

          if (books.length === 0) {
            content.innerHTML = `
              <div class="alert alert-info text-center">
                <i class="bi bi-info-circle me-2"></i>
                Thư viện này chưa có sách nào. Hãy dùng nút <strong>Thêm sách vào thư viện</strong> để thêm!
              </div>
            `;
            return;
          }

          let rows = "";
          books.forEach((book, i) => {
            const ngayThem = book.ngay_them
              ? new Date(book.ngay_them).toLocaleDateString("vi-VN")
              : "—";
            const slTrong = book.so_luong_trong_thu_vien ?? "—";
            const slTon = book.slton ?? 0;
            const slClass = slTon === 0
              ? "text-danger fw-bold"
              : slTon <= 5 ? "text-warning fw-bold" : "text-success fw-bold";
            rows += `
              <tr>
                <td>${i + 1}</td>
                <td><strong>${book.ten_sach || "—"}</strong></td>
                <td>${book.tac_gia || "—"}</td>
                <td><span class="badge bg-secondary">${book.ten_theloai || "—"}</span></td>
                <td>${book.nam_xuat_ban || "—"}</td>
                <td><span class="badge bg-primary">${slTrong}</span></td>
                <td><span class="${slClass}">${slTon}</span></td>
                <td><small class="text-muted">${ngayThem}</small></td>
              </tr>`;
          });

          content.innerHTML = `
            <div class="mb-3">
              <span class="badge bg-success fs-6">
                <i class="bi bi-check-circle me-1"></i>
                Tổng: ${books.length} cuốn sách
              </span>
            </div>
            <div class="table-responsive">
              <table class="table table-hover table-striped align-middle">
                <thead class="table-dark">
                  <tr>
                    <th>#</th><th>Tên sách</th><th>Tác giả</th>
                    <th>Thể loại</th><th>Năm XB</th>
                    <th>SL trong TV</th><th>SL tồn kho</th><th>Ngày thêm</th>
                  </tr>
                </thead>
                <tbody>${rows}</tbody>
              </table>
            </div>`;

        } catch (error) {
          console.error("❌ Lỗi khi load sách thư viện:", error);
          content.innerHTML = `
            <div class="alert alert-danger">
              <i class="bi bi-exclamation-triangle me-2"></i>
              <strong>Lỗi:</strong> ${error.message}
            </div>`;
        }
      };

      // Hàm mở modal sửa thư viện
      window.openEditLibraryModal = async function (libraryId) {
        console.log("📝 openEditLibraryModal - ID:", libraryId);
        // Hàm này sẽ được định nghĩa đầy đủ trong script tag sau
        // Tạm thời redirect đến trang update
        window.location.href = `/admin/thu_vien/update/${libraryId}`;
      };

      // Hàm thêm sách vào thư viện sẽ được định nghĩa đầy đủ trong script tag sau modal
      // Stub function đơn giản để tránh lỗi khi onclick được parse
      window.addBookToLibrary = async function () {
        console.log(
          "📚 addBookToLibrary stub được gọi - hàm đầy đủ sẽ được định nghĩa sau"
        );
        // Hàm đầy đủ sẽ override hàm này trong script tag sau modal
      };

      // Hàm chọn ảnh - Stub function để tránh lỗi khi onclick được parse
      window.selectImage = function () {
        // Kiểm tra xem hàm đầy đủ đã được định nghĩa chưa
        const fullFn = window.selectImage;
        const fnStr = fullFn.toString();
        // Nếu hàm đã được override (có "getElementById" và không có "stub")
        if (fnStr.includes("getElementById") && !fnStr.includes("stub")) {
          // Gọi hàm đầy đủ
          return fullFn();
        }
        // Nếu chưa có hàm đầy đủ, đợi một chút và thử lại
        setTimeout(() => {
          const checkFn = window.selectImage;
          const checkStr = checkFn.toString();
          if (
            checkStr.includes("getElementById") &&
            !checkStr.includes("stub")
          ) {
            checkFn();
          } else {
            console.error(
              "❌ Hàm selectImage chưa được load. Vui lòng refresh trang."
            );
          }
        }, 100);
      };

      // Hàm chọn ảnh cho form sửa - Stub function
      window.selectEditImage = function () {
        // Kiểm tra xem hàm đầy đủ đã được định nghĩa chưa
        const fullFn = window.selectEditImage;
        const fnStr = fullFn.toString();
        // Nếu hàm đã được override (có "getElementById" và không có "stub")
        if (fnStr.includes("getElementById") && !fnStr.includes("stub")) {
          // Gọi hàm đầy đủ
          return fullFn();
        }
        // Nếu chưa có hàm đầy đủ, đợi một chút và thử lại
        setTimeout(() => {
          const checkFn = window.selectEditImage;
          const checkStr = checkFn.toString();
          if (
            checkStr.includes("getElementById") &&
            !checkStr.includes("stub")
          ) {
            checkFn();
          } else {
            console.error(
              "❌ Hàm selectEditImage chưa được load. Vui lòng refresh trang."
            );
          }
        }, 100);
      };

      // Hàm xử lý chọn ảnh - Stub function để tránh lỗi khi onchange được parse
      window.handleImageSelection = function (input) {
        // Kiểm tra xem hàm đầy đủ đã được định nghĩa chưa
        const fullFn = window.handleImageSelection;
        const fnStr = fullFn.toString();
        // Nếu hàm đã được override (có "getElementById" và không có "stub")
        if (fnStr.includes("getElementById") && !fnStr.includes("stub")) {
          // Gọi hàm đầy đủ
          return fullFn(input);
        }
        // Nếu chưa có hàm đầy đủ, đợi một chút và thử lại
        setTimeout(() => {
          const checkFn = window.handleImageSelection;
          const checkStr = checkFn.toString();
          if (
            checkStr.includes("getElementById") &&
            !checkStr.includes("stub")
          ) {
            checkFn(input);
          } else {
            console.error(
              "❌ Hàm handleImageSelection chưa được load. Vui lòng refresh trang."
            );
          }
        }, 100);
      };

      // Hàm xử lý chọn ảnh cho form sửa - Stub function
      window.handleEditImageSelection = function (input) {
        // Kiểm tra xem hàm đầy đủ đã được định nghĩa chưa
        const fullFn = window.handleEditImageSelection;
        const fnStr = fullFn.toString();
        // Nếu hàm đã được override (có "getElementById" và không có "stub")
        if (fnStr.includes("getElementById") && !fnStr.includes("stub")) {
          // Gọi hàm đầy đủ
          return fullFn(input);
        }
        // Nếu chưa có hàm đầy đủ, đợi một chút và thử lại
        setTimeout(() => {
          const checkFn = window.handleEditImageSelection;
          const checkStr = checkFn.toString();
          if (
            checkStr.includes("getElementById") &&
            !checkStr.includes("stub")
          ) {
            checkFn(input);
          } else {
            console.error(
              "❌ Hàm handleEditImageSelection chưa được load. Vui lòng refresh trang."
            );
          }
        }, 100);
      };

      console.log("✅ Các hàm global đã được định nghĩa trong head");
      console.log(
        "✅ handleDeleteLibraryClick:",
        typeof window.handleDeleteLibraryClick
      );
      console.log(
        "✅ handleViewBooksClick:",
        typeof window.handleViewBooksClick
      );
      console.log(
        "✅ openEditLibraryModal:",
        typeof window.openEditLibraryModal
      );
    </script>
  </head>
  <body>
    <header>
      <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
          <a class="navbar-brand" href="/admin">
            <i class="bi bi-building me-2"></i>Quản lý Thư Viện
          </a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navMain"
            aria-controls="navMain"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav ms-auto">
              <li class="nav-item">
                <a class="nav-link" href="/admin">
                  <i class="bi bi-house-door me-1"></i>Trang chủ
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link active" href="/admin/thu_vien">
                  <i class="bi bi-building me-1"></i>Thư viện
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/admin/the_loai">
                  <i class="bi bi-tags me-1"></i>Thể loại
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/admin/sach">
                  <i class="bi bi-book me-1"></i>Sách
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/admin/muon_sach">
                  <i class="bi bi-journal-text me-1"></i>Mượn sách
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/admin/don_hang">
                  <i class="bi bi-cart-check me-1"></i>Đơn hàng
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/shop">
                  <i class="bi bi-shop me-1"></i>Cửa hàng
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/">
                  <i class="bi bi-geo-alt-fill me-1"></i>Xem bản đồ
                </a>
              </li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <main class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2> <i class="bi bi-building"></i> Quản lý Thư viện</h2>
        <div>
          <button
            class="btn btn-success me-2"
            data-bs-toggle="modal"
            data-bs-target="#addBookToLibraryModal"
          >
            <i class="bi bi-book-plus"></i> Thêm sách vào thư viện
          </button>
          <a class="btn btn-primary" href="#addLibraryForm">
            <i class="bi bi-plus-circle"></i> Thêm thư viện
          </a>
        </div>
      </div>

      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h5 class="mb-0">Thêm Thư viện</h5>
        </div>
        <div class="card-body">
          <form
            id="addLibraryForm"
            method="POST"
            action="/admin/thu_vien/add"
            enctype="multipart/form-data"
          >
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label">ID Thư viện</label>
                <input
                  type="text"
                  name="ID_thuvien"
                  class="form-control"
                  placeholder="ID Thư viện"
                  required
                />
              </div>
              <div class="col-md-8">
                <label class="form-label">Tên thư viện</label>
                <input
                  type="text"
                  name="Ten_thuvien"
                  class="form-control"
                  placeholder="Tên thư viện"
                  required
                />
              </div>
              <div class="col-12">
                <label class="form-label">Địa chỉ</label>
                <input
                  type="text"
                  name="Dia_chi"
                  class="form-control"
                  placeholder="Địa chỉ"
                />
              </div>
              <div class="col-12">
                <div class="row g-3">
                  <div class="col-6 col-md-3">
                    <div class="form-check form-switch">
                      <input
                        class="form-check-input"
                        type="checkbox"
                        name="Wifi"
                        id="wifi"
                      />
                      <label class="form-check-label" for="wifi">Wifi</label>
                    </div>
                  </div>
                  <div class="col-6 col-md-3">
                    <div class="form-check form-switch">
                      <input
                        class="form-check-input"
                        type="checkbox"
                        name="Phongdoc"
                        id="phongdoc"
                      />
                      <label class="form-check-label" for="phongdoc"
                        >Phòng đọc</label
                      >
                    </div>
                  </div>
                  <div class="col-6 col-md-3">
                    <div class="form-check form-switch">
                      <input
                        class="form-check-input"
                        type="checkbox"
                        name="Canteen"
                        id="canteen"
                      />
                      <label class="form-check-label" for="canteen"
                        >Canteen</label
                      >
                    </div>
                  </div>
                  <div class="col-6 col-md-3">
                    <div class="form-check form-switch">
                      <input
                        class="form-check-input"
                        type="checkbox"
                        name="Dieuhoa"
                        id="dieuhoa"
                      />
                      <label class="form-check-label" for="dieuhoa"
                        >Điều hòa</label
                      >
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label">Latitude</label>
                <input
                  type="number"
                  name="Latitude"
                  placeholder="Latitude"
                  step="any"
                  class="form-control"
                />
              </div>
              <div class="col-md-6">
                <label class="form-label">Longitude</label>
                <input
                  type="number"
                  name="Longitude"
                  placeholder="Longitude"
                  step="any"
                  class="form-control"
                />
              </div>
              <div class="col-md-6">
                <label class="form-label">Loại thư viện</label>
                <select name="phanloai" class="form-select" required>
                  <option value="" disabled selected>Chọn loại thư viện</option>
                  <option value="Thư viện công cộng">Thư viện công cộng</option>
                  <option value="Thư viện tư nhân">Thư viện tư nhân</option>
                  <option value="Thư viện trường học">
                    Thư viện trường học
                  </option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Ảnh 360</label>
                <div class="input-group">
                  <input
                    type="text"
                    name="Anh360Path"
                    id="Anh360Path"
                    class="form-control"
                    placeholder="Đường dẫn ảnh hoặc chọn file"
                    readonly
                  />
                  <button
                    type="button"
                    class="btn btn-outline-secondary"
                    onclick="selectImage()"
                  >
                    <i class="bi bi-folder-open"></i> Chọn
                  </button>
                </div>
                <input
                  type="file"
                  name="Anh360"
                  id="Anh360"
                  accept="image/*"
                  class="form-control mt-2"
                  onchange="handleImageSelection(this)"
                  style="display: none"
                />
                <small class="form-text text-muted">
                  <i class="bi bi-info-circle"></i> Chọn ảnh từ máy tính để
                  upload trực tiếp. Ảnh sẽ được lưu tự động vào hệ thống.
                </small>
                <div id="imagePreview" class="mt-2" style="display: none">
                  <img
                    id="previewImg"
                    class="img-thumbnail"
                    style="max-width: 200px; max-height: 200px"
                  />
                </div>
              </div>
              <div class="col-12">
                <button
                  type="submit"
                  class="btn btn-primary"
                  id="submitLibraryBtn"
                  style="
                    position: relative;
                    z-index: 1000;
                    pointer-events: auto;
                  "
                >
                  <i class="bi bi-plus-circle me-2"></i>Thêm Thư viện
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <div
        id="errorMessage"
        class="alert alert-danger"
        style="display: none"
      ></div>

      <div class="card shadow-sm">
        <div class="card-header bg-white">
          <h5 class="mb-0">Danh sách các Thư viện</h5>
        </div>
        <div class="card-body">
          <% if (!thuVien || thuVien.length === 0) { %>
          <div class="alert alert-info text-center">
            <h6 class="mb-2">Không có thư viện nào trong danh sách</h6>
            <p class="mb-3">Bảng có thể trống hoặc có lỗi kết nối database</p>
            <button onclick="testDatabase()" class="btn btn-outline-primary">
              Kiểm tra Database
            </button>
          </div>
          <% } else { %>
          <div class="table-responsive">
            <table
              id="libraryTable"
              class="table table-hover table-striped align-middle mb-0"
            >
              <thead class="table-light">
                <tr>
                  <th>ID Thư viện</th>
                  <th>Tên Thư viện</th>
                  <th>Địa chỉ</th>
                  <th>Wifi</th>
                  <th>Phòng đọc</th>
                  <th>Canteen</th>
                  <th>Điều hòa</th>
                  <th>Latitude</th>
                  <th>Longitude</th>
                  <th>Loại thư viện</th>
                  <th>Ảnh 360</th>
                  <th>Sách</th>
