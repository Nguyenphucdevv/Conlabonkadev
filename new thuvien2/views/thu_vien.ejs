            }
          }

          function setupFormSubmit(form) {
            // Kiểm tra xem đã có listener chưa
            if (form.hasAttribute("data-submit-handler-attached")) {
              console.log("⚠️ Form submit handler đã được gắn rồi");
              return;
            }

            form.setAttribute("data-submit-handler-attached", "true");

            form.addEventListener("submit", async function(event) {
              console.log("📝 Form submit event triggered!");
              // QUAN TRỌNG: preventDefault phải được gọi đầu tiên
              event.preventDefault();
              event.stopPropagation();
              event.stopImmediatePropagation();

              const errorDiv = document.getElementById("errorMessage");
              const submitBtn = document.getElementById("submitLibraryBtn") || event.target.querySelector('button[type="submit"]');

              if (!errorDiv) {
                console.error("❌ Không tìm thấy errorDiv");
                alert("Lỗi: Không tìm thấy phần tử hiển thị lỗi");
                return;
              }

              if (!submitBtn) {
                console.error("❌ Không tìm thấy submitBtn");
                errorDiv.className = "alert alert-danger";
                errorDiv.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i>Lỗi: Không tìm thấy nút submit';
                errorDiv.style.display = "block";
                return;
              }

              const originalBtnText = submitBtn.innerHTML;

              errorDiv.style.display = "none";
              submitBtn.disabled = true;
              submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang thêm...';

              const formData = new FormData(event.target);

              // Validation đầy đủ
              const ID_thuvien = formData.get("ID_thuvien")?.trim();
              const Ten_thuvien = formData.get("Ten_thuvien")?.trim();
              const phanloai = formData.get("phanloai")?.trim();

              if (!ID_thuvien || !Ten_thuvien || !phanloai) {
                errorDiv.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i>Vui lòng điền đầy đủ thông tin bắt buộc: ID thư viện, Tên thư viện và Loại thư viện';
                errorDiv.style.display = "block";
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnText;
                return;
              }

              console.log('📤 Gửi dữ liệu thư viện:', {
                ID_thuvien,
                Ten_thuvien,
                phanloai,
                Dia_chi: formData.get("Dia_chi"),
                Wifi: formData.get("Wifi"),
                Phongdoc: formData.get("Phongdoc"),
                Canteen: formData.get("Canteen"),
                Dieuhoa: formData.get("Dieuhoa"),
                Latitude: formData.get("Latitude"),
                Longitude: formData.get("Longitude"),
                hasFile: formData.get("Anh360") ? true : false
              });

              try {
                const response = await fetch("/admin/thu_vien/add", {
                  method: "POST",
                  headers: {
                    "X-Requested-With": "XMLHttpRequest"
                  },
                  body: formData,
                });

                console.log('📥 Response status:', response.status);
                console.log('📥 Response ok:', response.ok);
                console.log('📥 Response headers:', Object.fromEntries(response.headers.entries()));

                // Kiểm tra status code trước
                if (!response.ok) {
                  let errorText = "";
                  try {
                    errorText = await response.text();
                  } catch (textError) {
                    errorText = `HTTP ${response.status}: ${response.statusText}`;
                  }
                  console.error("❌ Server error (status not ok):", errorText);
                  errorDiv.className = "alert alert-danger";
                  errorDiv.innerHTML = `<i class="bi bi-exclamation-triangle me-2"></i><strong>Lỗi server (${response.status}):</strong> ${errorText.substring(0, 200)}`;
                  errorDiv.style.display = "block";
                  submitBtn.disabled = false;
                  submitBtn.innerHTML = originalBtnText;
                  return;
                }

                // Thử parse JSON - chỉ parse một lần
                let result;
                const contentType = response.headers.get("content-type") || "";

                try {
                  // Luôn thử parse JSON trước
                  const responseText = await response.text();
                  console.log("📥 Response text:", responseText.substring(0, 200));

                  try {
                    result = JSON.parse(responseText);
                    console.log('📥 Parsed JSON:', result);
                  } catch (parseError) {
                    // Nếu không parse được JSON, coi như lỗi
                    console.error("❌ Không thể parse JSON:", parseError);
                    errorDiv.className = "alert alert-danger";
                    errorDiv.innerHTML = `<i class="bi bi-exclamation-triangle me-2"></i><strong>Lỗi:</strong> Server trả về dữ liệu không hợp lệ: ${responseText.substring(0, 100)}`;
                    errorDiv.style.display = "block";
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnText;
                    return;
                  }
                } catch (readError) {
                  console.error("❌ Lỗi khi đọc response:", readError);
                  errorDiv.className = "alert alert-danger";
                  errorDiv.innerHTML = `<i class="bi bi-exclamation-triangle me-2"></i><strong>Lỗi:</strong> Không thể đọc response từ server`;
                  errorDiv.style.display = "block";
                  submitBtn.disabled = false;
                  submitBtn.innerHTML = originalBtnText;
                  return;
                }

                // Xử lý kết quả
                if (result && result.success) {
                  console.log("✅ Thêm thư viện thành công!");
                  errorDiv.className = "alert alert-success";
                  errorDiv.innerHTML = `<i class="bi bi-check-circle me-2"></i>Thêm thư viện thành công! Đang tải lại trang...`;
                  errorDiv.style.display = "block";

                  // Reset form
                  event.target.reset();
                  const imagePreview = document.getElementById("imagePreview");
                  if (imagePreview) {
                    imagePreview.style.display = "none";
                  }

                  // Reload sau 1 giây
                  setTimeout(() => {
                    console.log("🔄 Reloading page...");
                    window.location.reload();
                  }, 1000);
                } else {
                  console.error("❌ Thêm thư viện thất bại:", result);
                  errorDiv.className = "alert alert-danger";
                  errorDiv.innerHTML = `<i class="bi bi-exclamation-triangle me-2"></i><strong>Lỗi:</strong> ${result?.error || result?.message || 'Không xác định được lỗi'}`;
                  errorDiv.style.display = "block";
                  submitBtn.disabled = false;
                  submitBtn.innerHTML = originalBtnText;
                }
              } catch (error) {
                console.error("❌ Network error:", error);
                console.error("❌ Error stack:", error.stack);
                errorDiv.className = "alert alert-danger";
                errorDiv.innerHTML = `<i class="bi bi-exclamation-triangle me-2"></i><strong>Lỗi kết nối:</strong> ${error.message}`;
                errorDiv.style.display = "block";
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnText;
              }
            });
            console.log("✅ Form submit handler đã được gắn thành công");
          }

