          // ===== CÁC HÀM XỬ LÝ MODAL SỬA THƯ VIỆN =====

          // Hàm mở modal sửa và load dữ liệu - Override định nghĩa stub trong head
          window.openEditLibraryModal = async function(libraryId) {
