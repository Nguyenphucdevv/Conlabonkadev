    <!-- Script định nghĩa hàm loadAllBooks NGAY SAU MODAL - Đảm bảo được định nghĩa sớm -->
    <script>
      // Hàm test API (có thể gọi từ console)
      window.testLoadBooksAPI = async function () {
        try {
          console.log("🧪 Test API: /admin/thu_vien/all-books");
          const response = await fetch("/admin/thu_vien/all-books");
          const data = await response.json();
          console.log("✅ Test thành công:", data);
          return data;
        } catch (error) {
          console.error("❌ Test thất bại:", error);
          return null;
        }
      };

      // Hàm load TẤT CẢ sách từ bảng sach - Định nghĩa SỚM để có thể sử dụng ngay
      window.loadAllBooks = async function () {
        try {
          console.log("📚 ===== BẮT ĐẦU LOAD TẤT CẢ SÁCH =====");

          const bookSelect = document.getElementById("selectBook");
          if (!bookSelect) {
            console.error("❌ Không tìm thấy selectBook element");
            console.error("❌ Đang tìm lại sau 200ms...");
            setTimeout(() => {
              const retrySelect = document.getElementById("selectBook");
              if (retrySelect) {
                console.log("✅ Tìm thấy selectBook sau retry");
                window.loadAllBooks();
              } else {
                console.error("❌ Vẫn không tìm thấy selectBook");
              }
            }, 200);
            return;
          }

          console.log("✅ Tìm thấy selectBook element");

          bookSelect.innerHTML =
            '<option value="">-- Đang tải sách... --</option>';
          bookSelect.disabled = true;

          const apiUrl = "/admin/thu_vien/all-books";
          console.log("📡 Gọi API:", apiUrl);

          const response = await fetch(apiUrl);
          console.log("📥 Response status:", response.status);
          console.log("📥 Response ok:", response.ok);

          // Đọc response body một lần duy nhất
          let responseData;
          const contentType = response.headers.get("content-type") || "";

          if (contentType.includes("application/json")) {
            responseData = await response.json();
          } else {
            const textData = await response.text();
            try {
              responseData = JSON.parse(textData);
            } catch (e) {
              responseData = { error: textData };
            }
          }

          // Kiểm tra response sau khi đã đọc
          if (!response.ok) {
            const errorText =
              responseData.error ||
              responseData.message ||
              `HTTP ${response.status}`;
            console.error("❌ Response error:", errorText);
            throw new Error(
              `HTTP error! status: ${response.status}, message: ${errorText}`
            );
          }

          const data = responseData;
          console.log("📥 Dữ liệu nhận được:", data);
          console.log("📥 Success:", data.success);
          console.log("📥 Số sách:", data.books ? data.books.length : 0);

          bookSelect.innerHTML = '<option value="">-- Chọn sách --</option>';
          bookSelect.disabled = false;

          if (data.success && data.books && data.books.length > 0) {
            console.log(
              `✅ Tìm thấy ${data.books.length} sách, đang thêm vào dropdown...`
            );

            let addedCount = 0;
            data.books.forEach((book) => {
              const option = document.createElement("option");
              option.value = book.id_sach;

              // Hiển thị thông tin sách: Tên - Tác giả (Thể loại) - Số lượng tồn
              const tacGia = book.tac_gia || "Không có";
              const theLoai = book.ten_theloai || "Không có";
              const slTon = book.slton || 0;

              option.textContent = `${book.ten_sach} - ${tacGia} (${theLoai}) - Tồn: ${slTon}`;
              option.dataset.available = slTon;
              option.dataset.tongsl = book.tongsl || 0;

              bookSelect.appendChild(option);
              addedCount++;
            });

            console.log(`✅ Đã thêm ${addedCount} sách vào dropdown`);
            console.log(
              "✅ Dropdown hiện có",
              bookSelect.options.length,
              "options"
            );
          } else {
            console.warn("⚠️ Không có sách nào trong response");
            const option = document.createElement("option");
            option.value = "";
            option.textContent = "-- Không có sách nào trong hệ thống --";
            option.disabled = true;
            bookSelect.appendChild(option);
          }

          console.log("📚 ===== HOÀN THÀNH LOAD SÁCH =====");
        } catch (error) {
          console.error("❌ Lỗi khi load sách:", error);
          console.error("❌ Error stack:", error.stack);
          const bookSelect = document.getElementById("selectBook");
          if (bookSelect) {
            bookSelect.innerHTML = `<option value="">-- Lỗi: ${error.message} --</option>`;
            bookSelect.disabled = false;
          }
          alert("Có lỗi xảy ra khi load danh sách sách: " + error.message);
        }
      };

      console.log(
        "✅ Hàm loadAllBooks đã được định nghĩa:",
        typeof window.loadAllBooks
      );

      // Gắn event listener ngay khi hàm đã được định nghĩa
      (function () {
        function setupModalListener() {
          const modal = document.getElementById("addBookToLibraryModal");
          if (!modal) {
            console.warn("⚠️ Modal chưa tồn tại, sẽ thử lại sau 200ms");
            setTimeout(setupModalListener, 200);
            return;
          }

          // Kiểm tra xem đã có listener chưa để tránh duplicate
          if (modal.hasAttribute("data-modal-listener-attached")) {
            console.log("✅ Event listener đã được gắn rồi");
            return;
          }

          modal.setAttribute("data-modal-listener-attached", "true");

          modal.addEventListener("show.bs.modal", function () {
            console.log("📚 Modal event triggered - show.bs.modal");

            // Reset dropdown sách về trạng thái ban đầu
            const bookSelect = document.getElementById("selectBook");
            if (bookSelect) {
              bookSelect.innerHTML =
                '<option value="">-- Chọn sách --</option>';
              bookSelect.disabled = false;
            }

            // Reset dropdown thư viện
            const librarySelect = document.getElementById("selectLibrary");
            if (librarySelect) {
              librarySelect.value = "";
            }

            // Load tất cả sách khi modal mở (sau khi modal đã hiển thị)
            if (typeof window.loadAllBooks === "function") {
              console.log("✅ Gọi window.loadAllBooks");
              setTimeout(() => {
                window.loadAllBooks();
              }, 200);
            } else {
              console.error("❌ window.loadAllBooks không tồn tại!");
            }
          });

          console.log("✅ Đã gắn event listener vào modal (inline script)");
        }

        // Chạy ngay nếu DOM đã sẵn sàng, nếu không thì đợi DOM ready
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", setupModalListener);
        } else {
          setupModalListener();
        }
      })();

      // Hàm thêm sách vào thư viện - Định nghĩa SỚM để có thể gọi từ onclick
      window.addBookToLibrary = async function () {
        const form = document.getElementById("addBookToLibraryForm");
        if (!form) {
          alert("Lỗi: Không tìm thấy form thêm sách");
          return;
        }

        const formData = new FormData(form);
        const library_id = formData.get("library_id")?.trim();
        const book_id = formData.get("book_id")?.trim();
        const quantity = parseInt(formData.get("quantity"));
        const reason = formData.get("reason")?.trim();
        const note = formData.get("note")?.trim();

        console.log("📚 Thêm sách vào thư viện:", {
          library_id,
          book_id,
          quantity,
          reason,
          note,
        });

        // Validation
        if (!library_id || !book_id || !quantity) {
          alert(
            "Vui lòng điền đầy đủ thông tin bắt buộc: Thư viện, Sách và Số lượng"
          );
          return;
        }

        if (quantity <= 0) {
          alert("Số lượng phải lớn hơn 0");
          return;
        }

        // Kiểm tra số lượng tồn từ option đã chọn
        const selected =
          document.getElementById("selectBook").selectedOptions[0];
        const available = parseInt(selected?.dataset.available || "0");
        const tongsl = parseInt(selected?.dataset.tongsl || "0");

        console.log("📊 Thông tin sách:", {
          available,
          tongsl,
          requested: quantity,
        });

        if (quantity > available) {
          alert(
            `Số lượng không được vượt quá ${available} quyển còn lại trong kho`
          );
          return;
        }

        const data = {
          library_id,
          book_id,
          quantity,
          reason: reason || "",
          note: note || "",
        };

        try {
          const submitBtn = document.querySelector(
            "#addBookToLibraryModal .btn-success"
          );
          const originalText = submitBtn?.innerHTML;
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML =
              '<span class="spinner-border spinner-border-sm me-2"></span>Đang thêm...';
          }

          const response = await fetch("/admin/thu_vien/add-book", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          // Đọc response body một lần duy nhất
          let responseData;
          const contentType = response.headers.get("content-type") || "";

          if (contentType.includes("application/json")) {
            responseData = await response.json();
          } else {
            const textData = await response.text();
            try {
              responseData = JSON.parse(textData);
            } catch (e) {
              responseData = { error: textData };
            }
          }

          console.log("📥 Kết quả:", responseData);

          if (response.ok && responseData.success) {
            alert("✅ Thêm sách vào thư viện thành công!");
            form.reset();
            bootstrap.Modal.getInstance(
              document.getElementById("addBookToLibraryModal")
            )?.hide();
            location.reload();
          } else {
            alert(
              "❌ Lỗi: " +
                (responseData.message || responseData.error || "Không xác định")
            );
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.innerHTML = originalText;
            }
          }
        } catch (error) {
          console.error("❌ Lỗi khi thêm sách:", error);
          alert("❌ Có lỗi xảy ra khi thêm sách: " + error.message);
          const submitBtn = document.querySelector(
            "#addBookToLibraryModal .btn-success"
          );
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm sách';
          }
        }
      };

      console.log(
        "✅ Hàm addBookToLibrary đã được định nghĩa:",
        typeof window.addBookToLibrary
      );

      // Hàm chọn ảnh - Định nghĩa SỚM để có thể gọi từ onclick
      window.selectImage = function () {
        const fileInput = document.getElementById("Anh360");
        if (fileInput) {
          fileInput.click();
        } else {
          console.error("❌ Không tìm thấy input file Anh360");
        }
      };

      // Hàm chọn ảnh cho form sửa - Định nghĩa SỚM
      window.selectEditImage = function () {
        const fileInput = document.getElementById("editAnh360");
        if (fileInput) {
          fileInput.click();
        } else {
          console.error("❌ Không tìm thấy input file editAnh360");
        }
      };

      console.log(
        "✅ Hàm selectImage đã được định nghĩa:",
        typeof window.selectImage
      );
      console.log(
        "✅ Hàm selectEditImage đã được định nghĩa:",
        typeof window.selectEditImage
      );

      // Hàm xử lý chọn ảnh - Định nghĩa SỚM để có thể gọi từ onchange
      window.handleImageSelection = function (input) {
        if (input && input.files && input.files[0]) {
          const file = input.files[0];
          const pathInput = document.getElementById("Anh360Path");
          if (pathInput) {
            pathInput.value = file.name;
          }
          previewImage(input);
        }
      };

      // Hàm xử lý chọn ảnh cho form sửa - Định nghĩa SỚM
      window.handleEditImageSelection = function (input) {
        if (input && input.files && input.files[0]) {
          const file = input.files[0];
          const pathInput = document.getElementById("editAnh360Path");
          if (pathInput) {
            pathInput.value = file.name;
          }
          previewEditImage(input);
        }
      };

      // Hàm preview ảnh - Định nghĩa SỚM
      function previewImage(input) {
        const preview = document.getElementById("imagePreview");
        const previewImg = document.getElementById("previewImg");

        if (input && input.files && input.files[0]) {
          const reader = new FileReader();
          reader.onload = function (e) {
            if (previewImg) {
              previewImg.src = e.target.result;
            }
            if (preview) {
              preview.style.display = "block";
            }
          };
          reader.readAsDataURL(input.files[0]);
        } else {
          if (preview) {
            preview.style.display = "none";
          }
        }
      }

      // Hàm preview ảnh cho form sửa - Định nghĩa SỚM
      function previewEditImage(input) {
        const preview = document.getElementById("editImagePreview");
        const previewImg = document.getElementById("editPreviewImg");

        if (input && input.files && input.files[0]) {
          const reader = new FileReader();
          reader.onload = function (e) {
            if (previewImg) {
              previewImg.src = e.target.result;
            }
            if (preview) {
              preview.style.display = "block";
            }
          };
          reader.readAsDataURL(input.files[0]);
        } else {
          if (preview) {
            preview.style.display = "none";
          }
        }
      }

      console.log(
        "✅ Hàm handleImageSelection đã được định nghĩa:",
        typeof window.handleImageSelection
      );
      console.log(
        "✅ Hàm handleEditImageSelection đã được định nghĩa:",
        typeof window.handleEditImageSelection
      );
    </script>

    <script>
          // Các hàm global đã được định nghĩa trong <head>
          // Kiểm tra lại để đảm bảo chúng có sẵn
          console.log("🔍 Kiểm tra các hàm global sau khi DOM ready:");
          console.log("  - handleDeleteLibraryClick:", typeof window.handleDeleteLibraryClick);
          console.log("  - handleViewBooksClick:", typeof window.handleViewBooksClick);
          console.log("  - openEditLibraryModal:", typeof window.openEditLibraryModal);

          if (typeof window.handleDeleteLibraryClick !== 'function') {
            console.error("❌ handleDeleteLibraryClick chưa được định nghĩa!");
          }

          async function testDatabase() {
            try {
              const response = await fetch("/admin/thu_vien/test-data");
              const data = await response.json();

              if (data.success) {
                alert(
                  `Database OK!\nBảng thu_vien: ${data.tableExists}\nTổng bản ghi: ${data.totalRecords}\nCấu trúc: ${data.tableStructure.length} cột`
                );
                console.log("Database test result:", data);
              } else {
                alert(`Database Error: ${data.error}`);
                console.error("Database test failed:", data);
              }
            } catch (error) {
              alert(`Lỗi kết nối: ${error.message}`);
              console.error("Test failed:", error);
            }
          }

          // Thêm thư viện mới
          function initFormSubmit() {
            console.log("🔧 Đang setup form submit handler...");
            const addLibraryForm = document.getElementById("addLibraryForm");
            if (!addLibraryForm) {
              console.error("❌ Không tìm thấy form addLibraryForm");
              return false;
            }
            console.log("✅ Tìm thấy form addLibraryForm");
            setupFormSubmit(addLibraryForm);
            return true;
          }

          // Đảm bảo chạy sau khi DOM ready
          if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", function() {
              if (!initFormSubmit()) {
                // Retry sau 500ms nếu không tìm thấy
                setTimeout(() => {
                  initFormSubmit();
                }, 500);
              }
            });
          } else {
            // DOM đã sẵn sàng
            if (!initFormSubmit()) {
              setTimeout(() => {
                initFormSubmit();
