                  <td><%= tv.dia_chi %></td>
                  <td><%= tv.wifi ? 'Có' : 'Không' %></td>
                  <td><%= tv.phongdoc ? 'Có' : 'Không' %></td>
                  <td><%= tv.canteen ? 'Có' : 'Không' %></td>
                  <td><%= tv.dieuhoa ? 'Có' : 'Không' %></td>
