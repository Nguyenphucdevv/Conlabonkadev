<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="icon" type="image/jpeg" href="/images/thuvienavt.jpg" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <link rel="stylesheet" href="/thuvien.css" />
  </head>

  <body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top shadow-sm">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/chu-quan">
          <i class="bi bi-shop me-2"></i>
          Chủ quán - <%= library.ten_thuvien %>
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
          aria-controls="navbarNav"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <a class="nav-link active" href="/chu-quan">
                <i class="bi bi-house-door me-1"></i>Dashboard
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/chu-quan/sach">
                <i class="bi bi-book me-1"></i>Quản lý sách
              </a>
            </li>
          </ul>
          <ul class="navbar-nav">
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle me-1"></i><%= user.ho_ten || user.tai_khoan %>
              </a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <div class="container-fluid mt-5 pt-4">
      <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
          <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
              <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Thông tin thư viện</h5>
            </div>
            <div class="card-body">
              <h6><%= library.ten_thuvien %></h6>
              <p class="text-muted mb-2"><i class="bi bi-geo-alt me-1"></i><%= library.dia_chi %></p>
              
              <div class="mb-3">
                <small class="text-muted">Tiện ích:</small>
                <div class="mt-1">
                  <% if (library.wifi) { %>
                    <span class="badge bg-success me-1"><i class="bi bi-wifi"></i> WiFi</span>
                  <% } %>
                  <% if (library.phongdoc) { %>
                    <span class="badge bg-info me-1"><i class="bi bi-book"></i> Phòng đọc</span>
                  <% } %>
                  <% if (library.canteen) { %>
                    <span class="badge bg-warning me-1"><i class="bi bi-cup"></i> Canteen</span>
                  <% } %>
                  <% if (library.dieuhoa) { %>
                    <span class="badge bg-primary me-1"><i class="bi bi-snow"></i> Điều hòa</span>
                  <% } %>
                </div>
              </div>
              
              <div class="border-top pt-3">
                <div class="d-grid gap-2">
                  <a href="/chu-quan/sach" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-book me-1"></i>Quản lý sách
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Main Dashboard -->
        <div class="col-md-9">
          <!-- Welcome Card -->
          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <h4 class="card-title">
                <i class="bi bi-shop text-primary me-2"></i>
                Chào mừng, <%= user.ho_ten || user.tai_khoan %>!
              </h4>
              <p class="card-text text-muted">
                Bạn đang quản lý thư viện <strong><%= library.ten_thuvien %></strong>.
                Sử dụng menu bên trái để quản lý sách trong thư viện của bạn.
              </p>
            </div>
          </div>

          <!-- Statistics Cards -->
          <div class="row mb-4">
            <div class="col-md-4">
              <div class="card shadow-sm border-primary">
                <div class="card-body text-center">
                  <i class="bi bi-book display-4 text-primary mb-3"></i>
                  <h3 class="text-primary"><%= stats.tong_so_sach %></h3>
                  <p class="text-muted mb-0">Tổng số sách</p>
                </div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="card shadow-sm border-success">
                <div class="card-body text-center">
                  <i class="bi bi-stack display-4 text-success mb-3"></i>
                  <h3 class="text-success"><%= stats.tong_so_luong %></h3>
                  <p class="text-muted mb-0">Tổng số lượng</p>
                </div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="card shadow-sm border-info">
                <div class="card-body text-center">
                  <i class="bi bi-building display-4 text-info mb-3"></i>
                  <h3 class="text-info">1</h3>
                  <p class="text-muted mb-0">Thư viện quản lý</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Quick Actions -->
          <div class="card shadow-sm">
            <div class="card-header bg-light">
              <h5 class="mb-0"><i class="bi bi-lightning me-2"></i>Thao tác nhanh</h5>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-6">
                  <a href="/chu-quan/sach" class="btn btn-primary w-100">
                    <i class="bi bi-book me-2"></i>
                    <div class="text-start">
                      <div class="fw-bold">Xem danh sách sách</div>
                      <small>Quản lý sách trong thư viện</small>
                    </div>
                  </a>
                </div>
                <div class="col-md-6">
                  <button class="btn btn-outline-secondary w-100" disabled>
                    <i class="bi bi-graph-up me-2"></i>
                    <div class="text-start">
                      <div class="fw-bold">Thống kê</div>
                      <small>Sắp có</small>
                    </div>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    
    <!-- Custom JS -->
    <script>
      // Add any custom JavaScript here
      console.log('🏪 Chủ quán dashboard loaded');
    </script>
  </body>
</html>